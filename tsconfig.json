{
  "compilerOptions": {
    "target": "es2020",
    "module": "commonjs",
    "types": ["node", "mocha"],
    "declaration": true,
    "sourceMap": true,
    "rootDir": "src",
    "outDir": "dist",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true
  },
  "include": [
    "src/**/*"
  ],
  "exclude": [
    "src/examples"
  ]
}
